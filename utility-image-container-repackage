#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [[ $(id -u -n) = "root" ]]
then
	SUDO_HOME=/root

	USER="${SUDO_USER}"

	HOME=/home/"${USER}"
fi

if [[ -z $(command -v curl) ]]
then
	yes | apt-get install curl
fi

if [ ! -d "${HOME}"/.local/bin ]
then
	mkdir -p "${HOME}"/.local/bin
fi

frobulator="${HOME}"/.local/bin/frobulator

version_online=$(curl -s -L get.frbltr.app | grep 'version=' | cut -d '"' -f 2)

version_local=$(cat "${frobulator}" | grep 'version=' | cut -d '"' -f 2)

version_local="${version_local:-01-01-1970}"

date_online=$(date -d "${version_online:6:4}-${version_online:0:2}-${version_online:3:2}" +%s)

date_local=$(date -d "${version_local:6:4}-${version_local:0:2}-${version_local:3:2}" +%s)

if [ -f "${frobulator}" ] && [ "${date_online}" -gt "${date_local}" ]
then
	rm -r -f "${HOME}"/.local/bin/frobulator

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

if [ ! -f "${frobulator}" ]
then
	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${frobulator}"

# superuser ////////////////////////////////////////////////////////////////////

export self_arguments="${@}"

# frobulator.escalate

# script ///////////////////////////////////////////////////////////////////////

script="${BASH_SOURCE[0]}"

# version //////////////////////////////////////////////////////////////////////

version="07-13-2026"

# usage ////////////////////////////////////////////////////////////////////////

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"

# variables ////////////////////////////////////////////////////////////////////

platform="linux/aarch64"

# defaults /////////////////////////////////////////////////////////////////////

# functions ////////////////////////////////////////////////////////////////////

# update ///////////////////////////////////////////////////////////////////////

# frobulator.update

# frobulator.upgrade

# requirements /////////////////////////////////////////////////////////////////

list=(
	docker
	docker-clean
	docker-compose
	docker-registry
	docker.io
	7zip
	bunzip2
	gunzip
	tar
	unrar
	unzip
)

frobulator.require ${list[@]}

list=()

# configuration ////////////////////////////////////////////////////////////////

declare -A distributions_list=(
	[ubuntu]="18.04 20.04 22.04 24.04"
	[debian]="10 11 12 13"
	[fedora]="38 39 40 41"
)

for distribution in "${!distributions_list[@]}"
do
	for version in ${distributions[${distribution}]}
	do
		docker pull --quiet --platform="${platform}" "${distribution}:${version}"

		docker image save "${distribution}:${version}" | xz > "${distribution}-${version}-container.tar.xz"

		for archive_input in *container.tar.xz
		do
			archive_output="${archive_input/-container.tar.xz/.tar.xz}"

			temporary_directory=$(mktemp -d)

			frobulator.fwd "Extracting .."

			tar										\
				--extract							\
					--file="${archive_input}"   	\
					--xz                        	\
					--directory="${temporary_directory}"

			archive_layer=$(find "${temporary_directory}" -name "layer.tar")

			if [ -f "${archive_layer}" ]
			then
				xz -c "${archive_layer}" > "${archive_output}"

				echo "Successfully repackaged into ${archive_output}"
			else
				echo "'layer.tar' not found in the extracted content of ${archive_input}"
			fi

			rm -r -f "${temporary_directory}"

			rm -r -f "${archive_input}"
		done
	done
done
