#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [[ $(id -u -n) = "root" ]]
then
	SUDO_HOME=/root

	USER="${SUDO_USER}"

	HOME=/home/"${USER}"
fi

if [[ -z $(command -v curl) ]]
then
	yes | apt-get install curl
fi

if [ ! -d "${HOME}"/.local/bin ]
then
	mkdir -p "${HOME}"/.local/bin
fi

frobulator="${HOME}"/.local/bin/frobulator

version_online=$(curl -s -L get.frbltr.app | grep 'version=' | cut -d '"' -f 2)

version_local=$(cat "${frobulator}" | grep 'version=' | cut -d '"' -f 2)

version_local="${version_local:-01-01-1970}"

date_online=$(date -d "${version_online:6:4}-${version_online:0:2}-${version_online:3:2}" +%s)

date_local=$(date -d "${version_local:6:4}-${version_local:0:2}-${version_local:3:2}" +%s)

if [ -f "${frobulator}" ] && [ "${date_online}" -gt "${date_local}" ]
then
	rm -r -f "${HOME}"/.local/bin/frobulator

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

if [ ! -f "${frobulator}" ]
then
	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${frobulator}"

# script ///////////////////////////////////////////////////////////////////////

script="${BASH_SOURCE[0]}"

# defaults /////////////////////////////////////////////////////////////////////

# usage ////////////////////////////////////////////////////////////////////////

if [[ "${script}" = "${0}" ]]
then
	# implement from local version

	if [ $# -eq 0 ]
	then
		source "${BASH_SOURCE[0]}"

		return 0 2> "${sink}"

		if [ "${?}" -ne 0 ]
		then
			frobulator.scs "Implemented" "[ ${PWD}/${script} ]"
			echo
		fi
	fi

	file_source="${script}"

	file_install="${file_source}"

	directory_install="${HOME}"/.local/bin

	file_target="${directory_install}/${file_install}"

	while (($#))
	do
		case "${1}" in

			-i|--install)

				if [ ! -d "${directory_install}" ]
				then
					mkdir -p "${directory_install}"
				fi

				if [ "${file_source}" != "${file_target}" ]
				then
					cp "${file_source}" "${file_target}"

					chmod a+rx "${file_target}"

					source "${file_target}"

					frobulator.scs "Installed" "[ ${file_target} ]"

					echo
				fi
			;;

			-h|--help)

				echo
				echo -e "Usage: ./${script} | [OPTION]"
				echo
				echo "Options:"
				echo
				echo "	-i, --install    [I]nstall "${script}" to ${directory_install}"
				echo "	-h, --help       Show this [h]elp menu"
				echo

				exit
			;;

			*)

				echo
				echo "${script}: Unknown option '${1}'"
				echo "Type './${script} --help' for help and usage information."
				echo

				exit 1
			;;

		esac

		shift

	done
fi

# logout ///////////////////////////////////////////////////////////////////////

if [ -n "${TERMUX_VERSION}" ]
then
	frobulator.fwd "Logging out..."
	echo

	frobulator.timeout
fi

# dextop ///////////////////////////////////////////////////////////////////////

if [ -n "${TERMUX_VERSION}" ]
then
	# automatic session stop

	if [[ $(cat "${HOME}"/.dextop/dextop-logout) = "logout" ]]
	then
		# audio

		if [[ $(pgrep -f pulseaudio) ]]
		then
			pulseaudio --kill
		fi

		# display

		if [[ $(pgrep -f com.termux.x11) ]]
		then
			container-session -x

			pkill -f com.termux.x11

			pkill -f virgl
		fi
	fi
fi
