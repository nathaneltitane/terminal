#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = "root" ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="07-12-2026"

# usage ////////////////////////////////////////////////////////////////////////

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"

# variables ////////////////////////////////////////////////////////////////////

project="${1}"

# defaults /////////////////////////////////////////////////////////////////////

url="https://github.com/"
username="nathaneltitane"

depth=1

# functions ////////////////////////////////////////////////////////////////////

# requirements /////////////////////////////////////////////////////////////////

# configuration ////////////////////////////////////////////////////////////////

list+=(
	chatty
	dextop
	frobulator
	gutengrab
	l2cu
	mechablocks
	nathaneltitane
	pewpewprints
	terminal
)

if [ -n "${project}" ]
then
	list=(
		"${project}"
	)
fi

for project in ${list[@]}
do
	if [[ -d "${project}" ]]
	then
		frobulator.wrn "Project directory exists" "[ ${project} ]"
		echo

		frobulator.delete "${project}"
	fi

	git clone				\
		--quiet				\
		--depth "${depth}"	\
							"${url}"/"${username}"/"${project}" &

	frobulator.progress "clone" "[ ${project} ]"

done

list=()
