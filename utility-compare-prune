#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [ -f "${HOME}"/.local/bin/frobulator ]
then
	. "${HOME}"/.local/bin/frobulator

	frobulator.fwd 'Updating...'
	echo

	rm -r -f "${HOME}"/.local/bin/frobulator
else
	echo -n -e '[  ▷  ] Updating...'
	echo
fi

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = 'root' ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version='07-03-2026'

# variables ////////////////////////////////////////////////////////////////////

execute=false

list_device="${temporary}/device.list"
list_local="${temporary}/local.list"
list_delete="${temporary}/delete.list"

temporary="$(mktemp -d)"

# usage ////////////////////////////////////////////////////////////////////////

while (($#))
do
	case "${1}"
	in
		-d|--device)
			device="${2}"

			shift
		;;

		-l|--local)
			local="${2}"

			shift
		;;

		-e|--execute)
			execute=true
		;;

		-h|--help)
			echo
			echo "Usage:"
			echo
			echo "${script} -d /path/to/device/files -l /path/to/local/files"
			echo "${script} --device /path/to/device/files --local /path/to/local/files"
			echo "${script} -d /path/to/device/files -l /path/to/local/files --execute"
			echo
			echo "Options:"
			echo
			echo "-d, --device     Device directory used as reference."
			echo "-l, --local      Local directory to prune."
			echo "-e, --execute    Delete files from local directory."
			echo "-h, --help       Show help and usage information."
			echo

			exit
		;;

		"")
			:
		;;

		*)
			echo
			echo "Usage: ${script} -d [Device Directory] -l [Local Directory] -e [OPTION]"
			echo "${script}: Unknown option '${1}'"
			echo "Type './${script} --help' for help and usage information."
			echo

			exit 1
		;;

	esac

	shift

done

# defaults /////////////////////////////////////////////////////////////////////

# validate arguments

if [ -z "${device}" ] || [ -z "${local}" ]
then
	echo
	echo "Missing required directory."
	echo
	echo "Usage:"
	echo
	echo "${script} -d /path/to/device/files -l /path/to/local/files"
	echo "${script} --device /path/to/device/files --local /path/to/local/files"
	echo

	exit 1
fi

# validate directories

if [ ! -d "${device}" ] || [ ! -d "${local}" ]
then
	echo
	echo "Both arguments must be directories."
	echo

	exit 1
fi

# functions ////////////////////////////////////////////////////////////////////

index () {

	source="${1}"
	destination="${2}"

	cd "${source}" || exit 1

	find . -type f |
		sed 's|^\./||' |
		sort > "${destination}"

}


# index libraries

index "${device}" "${list_device}"

index "${local}" "${list_local}"

# determine files missing from the device

comm -1 -3 "${list_device}" "${list_local}" > "${list_delete}"

# display results

if [ -s "${list_delete}" ]
then
	echo
	echo "Files present locally but missing from device:"
	echo

	cat "${list_delete}"

	echo
	echo "Total files to remove:"

	wc -l < "${list_delete}"

	echo
else
	echo
	echo "No files need to be removed."
	echo
fi

echo

# execute changes

if ${execute}
then
	while IFS= read -r file
	do
		rm -v -- "${local}/${file}"

	done < "${list_delete}"

	# remove empty directories

	find "${local}" -type d -empty -delete

	echo
	echo "Local library pruned."
else
	echo "Dry run only. Nothing deleted."
	echo "Run again with --execute or -e to delete these files from the local directory."
fi

# cleanup

rm -rf "${temporary}"
