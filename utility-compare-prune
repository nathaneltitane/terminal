#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [ -f "${HOME}"/.local/bin/frobulator ]
then
	. "${HOME}"/.local/bin/frobulator

	frobulator.fwd 'Updating...'
	echo

	rm -r -f "${HOME}"/.local/bin/frobulator
else
	echo -n -e '[  ▷  ] Updating...'
	echo
fi

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = 'root' ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version='07-03-2026'

# variables ////////////////////////////////////////////////////////////////////

# parse arguments

device="${1}"
local="${2}"
flag="${3}"

execute=false

case "${flag}" in
	-e|--execute)
		execute=true
	;;
esac

# validate arguments

if [ -z "${device}" ] || [ -z "${local}" ]
then
	echo "Usage:"
	echo
	echo "utility-compare-prune /path/to/device/files /path/to/local/files"
	echo "utility-compare-prune /path/to/device/files /path/to/local/files --execute"
	echo "utility-compare-prune /path/to/device/files /path/to/local/files -e"

	exit 1
fi

# validate directories

if [ ! -d "${device}" ] || [ ! -d "${local}" ]
then
	echo "Both arguments must be directories."

	exit 1
fi

# create temporary workspace

temporary="$(mktemp -d)"

list_device="${temporary}/device.list"
list_local="${temporary}/local.list"
list_delete="${temporary}/delete.list"

# index device library

cd "${device}" || exit 1

find . -type f | sed 's|^\./||' | sort > "${list_device}"

# index local library

cd "${local}" || exit 1

find . -type f | sed 's|^\./||' | sort > "${list_local}"

# determine files missing from the device

comm -1 -3 "${list_device}" "${list_local}" > "${list_delete}"

# display results

echo
echo "Files present locally but missing from device:"
echo

cat "${list_delete}"

echo
echo "Total files to remove:"

wc -l < "${list_delete}"

echo

# execute changes

if ${execute}
then
	while IFS= read -r file
	do
		rm -v -- "${local}/${file}"

	done < "${list_delete}"

	# remove empty directories

	find "${local}" -type d -empty -delete

	echo
	echo "Local library pruned."
else
	echo "Dry run only. Nothing deleted."
	echo "Run again with --execute or -e to delete these files from the local directory."
fi

# cleanup

rm -rf "${temporary}"
