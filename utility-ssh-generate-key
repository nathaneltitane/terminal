#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [ -f "${HOME}"/.local/bin/frobulator ]
then
	rm -r -f "${HOME}"/.local/bin/frobulator
fi

if [[ -z $(command -v frobulator) ]]
then
	if [[ $(id -u -n) = "root" ]]
	then
		SUDO_HOME=/root

		USER="${SUDO_USER}"

		HOME=/home/"${USER}"
	fi

	if [[ -z $(command -v curl) ]]
	then
		yes | apt-get install curl
	fi

	if [ ! -d "${HOME}"/.local/bin ]
	then
		mkdir -p "${HOME}"/.local/bin
	fi

	if [[ $(id -u -n) = "root" ]]
	then
		chown "${USER}":"${USER}" "${HOME}"/.local/*

		chmod -R 777 "${HOME}"/.local/*
	fi

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${HOME}"/.local/bin/frobulator

# superuser ////////////////////////////////////////////////////////////////////

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="05-09-2026"

# usage ////////////////////////////////////////////////////////////////////////

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"

# variables ////////////////////////////////////////////////////////////////////

key_type="ed25519"

key_directory="${HOME}"

key="${key_directory}"/"${device}"

key_public="${key}.pub"

# defaults /////////////////////////////////////////////////////////////////////

# functions ////////////////////////////////////////////////////////////////////

# devices array

#!/usr/bin/env bash

# devices list

devices_list=(
	desktop
	notebook
	pi
	tablet
	phone
)

for device in ${devices_list[@]}
do

	# remove existing key files if they exist

	if [ -f "${key}" ]
	then
		rm					\
			--recursive		\
			--force			\
							"${key}"
	fi

	if [ -f "${key_public}" ]
	then
		rm					\
			--recursive		\
			--force			\
							"${key_public}"
	fi

	# generate key(s):
	# overwrite - no passphrase

	yes | ssh-keygen						\
		-t "${key_type}"					\
		-f "${key_directory}"/"${device}"	\
		-N ''								\
		-C "${USER}@${device}"

	# set ownership

	if [ -f "${key}" ]
	then
		chown 					\
			"${USER}:${USER}"	\
								"${key}"
	fi

	if [ -f "${key_public}" ]
	then
		chown					\
			"${USER}:${USER}"	\
								"${key_public}"
	fi

	# set permissions

	if [ -f "${key}" ]
	then
		chmod		\
			0600	\
					"${key}"
	fi

	if [ -f "${key_public}" ]
	then
		chmod		\
			0644	\
					"${key_public}"
	fi

done
