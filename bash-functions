# audio ////////////////////////////////////////////////////////////////////////

audio () {

	frobulator.require ffmpeg

	directory="${PWD}"
	extension="${1}"

	found=0

	# default conversion command

	convert_command () {

		ffmpeg					\
			-y					\
			-i "${file}"		\
			-f mp3				\
			-map_metadata 0		\
			-id3v2_version 3	"${file%.*}.mp3"
	}

	if [ "${extension}" = "flac" ]
	then
		# override for flac files with bitrate

		convert_command () {

			ffmpeg					\
				-y					\
				-i "${file}"		\
				-b:a 320k			\
				-map_metadata 0		\
				-id3v2_version 3	"${file%.*}.mp3"
		}
	fi

	# loop over all files

	for file in *
	do
		case "${file}" in
			*."${extension}")

				found=1

				convert_command

				rm					\
					--recursive		\
					--force			 "${file}"
				;;
		esac
	done

	# handle case where no matching files were found

	if [ "${found}" -eq 0 ]
	then
		frobulator.err "No files to convert with specified extension" "[ '${extension}' ]"

		return 1
	fi
}

play () {

	if [ -z "$(command -v mpv)" ]
	then
		frobulator.require mpv
	fi

	before="[${marker_spc}"
	after="${marker_spc}]"

	action="Playing"

	file="${1}"

	if [ $# -eq 2 ]
	then
		action="${1}"

		file="${2}"
	fi

	title="${file##*/}"


	# frobulator.pmt "${@}"

	# substitute standard input for function specific criteria:
	# [ ... ] action ///////////////////////////////////////////.../// [ title ]

	frobulator.pmt "${action}" "${title}"

	prompt="${prompt_string[@]}"

	ticker=(
		".  "
		".. "
		"..."
		" .."
		"  ."
		"   "
	)

	instance=0

	mpv					\
		--no-video		\
		--really-quiet	\
						"${file}" < "${sink}" > "${sink}" 2>&1 &

	PID=$!

	while [ -d /proc/"${PID}" ]
	do
		ticker_frame="${ticker[instance++%${#ticker[@]}]}"

		echo -n -e "\r${before}${ticker_frame}${after}${reset}${marker_spc}${prompt}\c"

		sleep 0.25
	done
}

# colors ///////////////////////////////////////////////////////////////////////

colors () {

	list=(
		tput
		printf
	)

	frobulator.require ${list[@]}

	list=()

	# print palette

	for foreground_color in {0..7}
	do
		set_foreground=$(tput setaf "${foreground_color}")

		for background_color in {0..7}
		do
			set_background=$(tput setab "${background_color}")

			echo -n "${set_background} ${set_foreground}"

			printf 'F:%s B:%s ' "${foreground_color}" "${background_color}"
		done

		# reset

		echo $(tput sgr0)
	done

	echo
}

hex () {

	# set IFS

	IFS=' '

	read r g b <<< "${@}"

	printf '%02x%02x%02x\n' ${r} ${g} ${b}

	# unset IFS

	IFS=''
}

rgb () {

	frobulator.require printf

	read hex <<< "${1}"

	[[ ${hex:0:1} = "#" ]] && hex=${hex:1:6}

	r=$((16#${hex:0:2}))
	g=$((16#${hex:2:2}))
	b=$((16#${hex:4:2}))

	printf '%03d %03d %03d\n' ${r} ${g} ${b}
}

