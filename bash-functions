# find /////////////////////////////////////////////////////////////////////////

find () {

	type="${1}"

	query="${2}"

	if [[ "${type}" =~ ^(d|dir|directory)$ ]]
	then
		type='d'

	elif [[ "${type}" =~ ^(f|file)$ ]]
	then
		type='f'
	else
		echo "unsupported type"
		echo

		exit 1
	fi

	if [[ $(command -v find) ]]
	then
		find								\
			"${PWD}"						\
				-type			"${type}"	\
				-iname 			"*${query}*"
	fi

}

# secure shell /////////////////////////////////////////////////////////////////

ssh () {

	destination="${1}"

	echo -n -e "[  $(tput setaf 3)${destination}$(tput sgr 0)  ] >_ ? "

	read -r -s password

	echo

	sshpass					\
		-p "${password}"	\
		--					\
							ssh "${@}"

	unset destination

	unset password

}

ssh-check () {

timeout="0.5"

lan="${1}"

if [ -z "${lan}" ]
then
    echo "Usage: ${0} <LAN_PREFIX> (e.g., ${0} 192.168.0 or 192.168.0.1)"

    exit 1
fi

# extract the first 3 octets from the input:
# sanitize to nnn.nnn.nnn.

lan=$(
		echo "${lan}" | grep -oE '^([0-9]{1,3}\.){2}[0-9]{1,3}' | awk -F. '{print $1"."$2"."$3"."}'
	)

	for i in {1..255}
	do
		ip="${lan}${i}"

		timeout "${timeout}" "${SHELL}" -c "echo > /dev/tcp/${ip}/22" 2> "${sink}"

		if [ ${?} -eq 0 ]
		then
			frobulator.scs "SSH open" "[ ${ip} ]"
		else
			frobulator.err "${ip}" &
		fi

	done | grep "open"

}

# audio control ////////////////////////////////////////////////////////////////

audio-combine () {

	sink_index () {

		sink_name="${1}"

		pactl list short sinks | grep -F "${sink_name}" | cut -f 1 | head -n 1

	}

	bluetooth_connect () {

	bluetooth_address="${1}"

	timeout="${2:-10}"

	i=0

	bluetoothctl disconnect "${bluetooth_address}" >/dev/null 2>&1

	while [ "${i}" -lt "${timeout}" ]
	do

		bluetoothctl connect "${bluetooth_address}" > /dev/null 2>&1

		if bluetoothctl info "${bluetooth_address}" 2>/dev/null | grep -F 'Connected: yes' > /dev/null 2>&1
		then

			return 0

		fi

		sleep 1

		i=$(( i + 1 ))

	done

	return 1

}

	sink_wait () {

		sink_name="${1}"

		timeout="${2}"

		seconds=0

		while [ "${seconds}" -lt "${timeout}" ]
		do

			if pactl list short sinks | grep -F "	${sink_name}	" > /dev/null 2>&1
			then

				return 0

			fi

			sleep 1

			seconds=$(( seconds + 1 ))

		done

		return 1

	}

	sink_combined='bluez_sink_combined'

	bluetooth_address_a="FC:E8:06:19:8E:9C"
	bluetooth_address_b="FC:E8:06:19:77:00"

	bluetooth_address_label_a="${bluetooth_address_a//:/_}"
	bluetooth_address_label_b="${bluetooth_address_b//:/_}"

	sink_a="bluez_sink.${bluetooth_address_label_a}.a2dp_sink"
	sink_b="bluez_sink.${bluetooth_address_label_b}.a2dp_sink"

	# connect bluetooth devices

	bluetooth_connect "${bluetooth_address_a}"
	bluetooth_connect "${bluetooth_address_b}"

	if ! sink_wait "${sink_a}" 10 || ! sink_wait "${sink_b}" 10
	then

		echo "Error: one or both sinks not found after connect attempt."
		echo "Make sure bluetooth devices are paired and connected."
		echo "Run: 'pactl list short sinks' for more details."

		exit 1

	fi

	index_sink_a="$( sink_index "${sink_a}" )"
	index_sink_b="$( sink_index "${sink_b}" )"

	# unload any existing combined sink module with the same name

	existing_sink_combined="$(pactl list short sinks  | grep -F 'module-combine-sink' | cut -f 1 | head -n 1)"

	if [[ -n "${existing_sink_combined}" ]]
	then

		pactl unload-module "${existing_sink_combined}"

		wait
	fi

	# combine sinks

	pactl load-module module-combine-sink sink_name="${sink_combined}" slaves="${sink_a},${sink_b}"

	# activate combined sink

	pactl set-default-sink "${sink_combined}"

	# set volume levels

	pactl set-sink-volume ${sink_a} 100%

