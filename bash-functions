adb_device () {

	adb_download

	adb_set_environment

	if [ $# -gt 1 ]
	then
		device="-s ${@:2}"

		adb connect ${@:2}

		sleep 2
	fi
}

adb_write () {

	adb_download

	adb_set_environment

	hostname=$(adb ${device} shell getprop net.hostname)

	write_command"${@}"

	echo ${write_command@Q} | sed "s/ /%s/g" | xargs -0 adb "${device}" shell input text

	# enter

	adb_keycode 66

	# sleep for consecutive writes

	sleep 0.125
}

adb_reset_apk () {

	adb_download

	adb_set_environment

	application="${1}"
	activity="${2}"

	adb "${device}" shell	\
		pm clear "${application}"

	adb "${device}" shell	\
		am start			\
			--user 0		\
			-n "${application}"/"${application}"."${activity}"
}

