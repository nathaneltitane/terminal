#!/bin/bash

# dependencies /////////////////////////////////////////////////////////////////

if [[ $(id -u -n) = "root" ]]
then
	SUDO_HOME=/root

	USER="${SUDO_USER}"

	HOME=/home/"${USER}"
fi

if [[ -z $(command -v curl) ]]
then
	yes | apt-get install curl
fi

if [ ! -d "${HOME}"/.local/bin ]
then
	mkdir -p "${HOME}"/.local/bin
fi

frobulator="${HOME}"/.local/bin/frobulator

version_online=$(curl -s -L get.frbltr.app | grep 'version=' | cut -d '"' -f 2)

version_local=$(cat "${frobulator}" | grep 'version=' | cut -d '"' -f 2)

version_local="${version_local:-01-01-1970}"

date_online=$(date -d "${version_online:6:4}-${version_online:0:2}-${version_online:3:2}" +%s)

date_local=$(date -d "${version_local:6:4}-${version_local:0:2}-${version_local:3:2}" +%s)

if [ -f "${frobulator}" ] && [ "${date_online}" -gt "${date_local}" ]
then
	rm -r -f "${HOME}"/.local/bin/frobulator

	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

if [ ! -f "${frobulator}" ]
then
	curl -s -L get.frbltr.app > "${HOME}"/.local/bin/frobulator

	chmod +x "${HOME}"/.local/bin/frobulator
fi

. "${frobulator}"

# superuser ////////////////////////////////////////////////////////////////////

export self_arguments="${@}"

# frobulator.escalate

# script ///////////////////////////////////////////////////////////////////////

script=$(basename -- "${BASH_SOURCE[0]}")

# version //////////////////////////////////////////////////////////////////////

version="07-18-2026"

# usage ////////////////////////////////////////////////////////////////////////

execute=false
confirm=true

operation=""

while (($#))
do
	case "${1}"
	in
		-f|--from)
			if [ -z "${2}" ] || [[ "${2}" = -* ]]
			then
				echo
				echo "${script}: Missing directory after '${1}'."
				echo

				exit 1
			fi

			from="${2}"

			shift
		;;

		-t|--to)
			if [ -z "${2}" ] || [[ "${2}" = -* ]]
			then
				echo
				echo "${script}: Missing directory after '${1}'."
				echo

				exit 1
			fi

			to="${2}"

			shift
		;;

		-a|--add)
			if [ -n "${operation}" ] && [ "${operation}" != "add" ]
			then
				echo
				echo "${script}: Add and remove cannot be used together."
				echo

				exit 1
			fi

			operation="add"
		;;

		-r|--remove)
			if [ -n "${operation}" ] && [ "${operation}" != "remove" ]
			then
				echo
				echo "${script}: Add and remove cannot be used together."
				echo

				exit 1
			fi

			operation="remove"
		;;

		-e|--execute)
			execute=true
		;;

		-y|--yes)
			confirm=false
		;;

		-h|--help)
			echo
			echo "Usage:"
			echo
			echo "Dry run:"
			echo
			echo "${script} -f /path/to/from -t /path/to/to --add"
			echo
			echo "${script} -f /path/to/from -t /path/to/to --remove"
			echo
			echo "Execute with confirmation:"
			echo
			echo "${script} -f /path/to/from -t /path/to/to --add -e"
			echo
			echo "${script} -f /path/to/from -t /path/to/to --remove -e"
			echo
			echo "Execute without confirmation:"
			echo
			echo "${script} -f /path/to/from -t /path/to/to --add -e -y"
			echo
			echo "${script} -f /path/to/from -t /path/to/to --remove -e -y"
			echo
			echo "Options:"
			echo
			echo "-f, --from       Set [f]rom directory reference."
			echo "-t, --to         Set destination [t]o directory."
			echo "-a, --add        [A]dd files missing from to directory."
			echo "-r, --remove     [R]emove files missing from from directory."
			echo "-e, --execute    Ex[e]cute selected operation."
			echo "-y, --yes        Assume [y]es and skip confirmation."
			echo "-h, --help       Show [h]elp and usage information."
			echo

			exit
		;;

		"")
			:
		;;

		*)
			echo
			echo "Usage: ${script} -f [From] -t [To] --add | --remove"
			echo
			echo "${script}: Unknown option '${1}'"
			echo "Type './${script} --help' for help and usage information."
			echo

			exit 1
		;;
	esac

	shift
done

# prompt ///////////////////////////////////////////////////////////////////////

frobulator.script "Setting up ${script#*-}"

# variables ////////////////////////////////////////////////////////////////////

temporary="$(mktemp -d)"

list_from="${temporary}/from.list"
list_to="${temporary}/to.list"
list_changes="${temporary}/changes.list"

count_changes=0

reply=""

# defaults /////////////////////////////////////////////////////////////////////

# validate arguments

if [ -z "${from}" ]
then
	frobulator.err "Missing from directory."
	echo

	exit 1

elif [ -z "${to}" ]
then
	frobulator.err "Missing to directory."
	echo

	exit 1

elif [ -z "${operation}" ]
then
	frobulator.err "Missing operation."
	frobulator.nul "Specify either '--add' or '--remove'."
	echo

	exit 1
fi

if [ "${confirm}" = false ] && [ "${execute}" = false ]
then
	frobulator.err "'--yes' requires '--execute'."
	echo

	exit 1
fi

# validate directories

if [ ! -d "${from}" ]
then
	frobulator.err "From directory not found" "[ ${from} ]"
	echo

	exit 1

elif [ ! -d "${to}" ]
then
	frobulator.err "To directory not found" "[ ${to} ]"
	echo

	exit 1
fi

from=$(cd "${from}" && pwd -P)

to=$(cd "${to}" && pwd -P)

if [ "${from}" = "${to}" ]
then
	frobulator.err "From and to directories cannot be the same."
	echo

	exit 1
fi

# functions ////////////////////////////////////////////////////////////////////

index () {

	source="${1}"
	destination="${2}"

	cd "${source}"

	status="${?}"

	if [ "${status}" -ne 0 ]
	then
		return 1
	fi

	find . -type f | sed 's|^\./||' | sort > "${destination}"

	status="${?}"

	if [ "${status}" -ne 0 ]
	then
		return 1
	fi

	return 0

}

display () {

	source="${1}"

	number=0

	while IFS= read -r file
	do
		(( number++ ))

		frobulator.num "${number}" "${file}"

	done < "${source}"

}

add () {

	while IFS= read -r file
	do
		destination="${to}/${file}"

		mkdir -p "$(dirname -- "${destination}")"

		status="${?}"

		if [ "${status}" -ne 0 ]
		then
			frobulator.err "Failed to create directory" "[ ${destination} ]"
			echo

			return 1
		fi

		frobulator.add "Adding" "[ ${file} ]"
		echo

		cp -a -- "${from}/${file}" "${destination}"

		status="${?}"

		if [ "${status}" -ne 0 ]
		then
			frobulator.err "Failed to add" "[ ${file} ]"
			echo

			return 1
		fi

	done < "${list_changes}"

	return 0

}

remove () {

	while IFS= read -r file
	do
		frobulator.rem "Removing" "[ ${file} ]"
		echo

		rm -f -- "${to}/${file}"

		status="${?}"

		if [ "${status}" -ne 0 ]
		then
			frobulator.err "Failed to remove" "[ ${file} ]"
			echo

			return 1
		fi

	done < "${list_changes}"

	return 0

}

# update ///////////////////////////////////////////////////////////////////////

# frobulator.update

# frobulator.upgrade

# requirements /////////////////////////////////////////////////////////////////

list=(

)

frobulator.require "${list[@]}"

list=()

# configuration ////////////////////////////////////////////////////////////////

# index directories

index "${from}" "${list_from}" &

frobulator.progress index "[ from ]"

index "${to}" "${list_to}" &

frobulator.progress index "[ to ]"

# determine changes

if [ "${operation}" = "add" ]
then
	comm -2 -3 "${list_from}" "${list_to}" > "${list_changes}"

elif [ "${operation}" = "remove" ]
then
	comm -1 -3 "${list_from}" "${list_to}" > "${list_changes}"
fi

count_changes=$(wc -l < "${list_changes}")

# display changes

if [ "${count_changes}" -gt 0 ]
then
	if [ "${operation}" = "add" ]
	then
		frobulator.add "Files to be added" "[ ${count_changes} ]"

	elif [ "${operation}" = "remove" ]
	then
		frobulator.rem "Files to be removed" "[ ${count_changes} ]"
	fi

	echo

	display "${list_changes}"

	echo
else
	if [ "${operation}" = "add" ]
	then
		frobulator.inf "No files to be added."
		echo

	elif [ "${operation}" = "remove" ]
	then
		frobulator.inf "No files to be removed."
		echo
	fi

	frobulator.delete "${temporary}"

	exit 0
fi

# display dry run

if [ "${execute}" = false ]
then
	frobulator.wrn "Dry run only" "[ ${operation}: ${count_changes} ]"
	frobulator.nul "Run ${script} again with '--execute' to apply changes."
	echo

	frobulator.delete "${temporary}"

	exit 0
fi

# confirm operation

if [ "${confirm}" = true ]
then
	frobulator.separate

	if [ "${operation}" = "add" ]
	then
		frobulator.ask "Proceed with adding ${count_changes} files?"

	elif [ "${operation}" = "remove" ]
	then
		frobulator.ask "Proceed with removing ${count_changes} files?"
	fi

	frobulator.read reply

	if [[ "${reply}" != [yY]         ]] && \
	   [[ "${reply}" != [yY][eE][sS] ]]
	then
		frobulator.fwd "Operation cancelled."
		echo

		frobulator.delete "${temporary}"

		exit 0
	fi
fi

# execute operation

if [ "${operation}" = "add" ]
then
	frobulator.fwd "Adding..."
	echo

	add

	status="${?}"

	if [ "${status}" -ne 0 ]
	then
		frobulator.err "File addition failed."
		echo

		frobulator.delete "${temporary}"

		exit 1
	fi

	frobulator.inf "Files added to destination" "[ ${count_changes} ]"
	echo

elif [ "${operation}" = "remove" ]
then
	frobulator.fwd "Removing..."
	echo

	remove

	status="${?}"

	if [ "${status}" -ne 0 ]
	then
		frobulator.err "File removal failed."
		echo

		frobulator.delete "${temporary}"

		exit 1
	fi

	# remove empty directories

	find "${to}" -depth -type d -empty -delete

	status="${?}"

	if [ "${status}" -ne 0 ]
	then
		frobulator.err "Failed to remove empty directories."
		echo

		frobulator.delete "${temporary}"

		exit 1
	fi

	frobulator.inf "Files removed from destination" "[ ${count_changes} ]"
	echo
fi

# cleanup

frobulator.delete "${temporary}"
